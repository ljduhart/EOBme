<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET — Firebase Auth, Firestore, Storage; EOB upload/sync (EobRepository / EobViewModel);
         live insurance RSS via RetrofitClient / fetchLiveInsuranceNews in EobViewModel;
         Insurance Intelligence rotation (3 Becker's + 4 Healthcare Dive / 2h) via InsuranceNewsRotation -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ACCESS_NETWORK_STATE — connectivity checks before remote operations -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- CAMERA — hub Scan EOB → EobRoute.CameraCapture (CameraX); runtime request in EobNavHost -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- POST_NOTIFICATIONS — EobFirebaseMessagingService; runtime request API 33+ in EobNavHost -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- BILLING — Google Play Billing Library (BillingRepository / SubscriptionViewModel) -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <!-- Onboarding (Splash → Language → Intro → AuthChoice → Auth) via AppViewModel.
         Sign-up LegalAcceptanceText opens policy URLs with ACTION_VIEW (queries below). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <package android:name="com.android.vending" />
    </queries>
    <!-- Hub state (records, uniform bento grid via BentoCellLayout → HubBentoDestination routes in
         EobNavHost, Appeal Generator bento press/processing ring via EobViewModel.appealGeneratorBentoProcessing,
         history, insurance news split-pane bento via EobViewModel.insuranceNewsBentoSnapshot
         and newsFeedRevision, smart gold care-team cards with 4s shimmer delay, editable home
         insurance card via EobViewModel, Appeal letter edit/save gated by
         EobViewModel.appealLetterEditingEnabled, hub Settings gear → EobRoute.Settings with
         EobViewModel hubSettings, SubscriptionViewModel + BillingRepository for
         premium_access_tier + Silver/Gold SKUs, Firestore users/{uid}.subscriptionTier
         with legacy isPremium) + EobRepository; ML Kit document scanner upload pipeline via
         EobViewModel.processScannedDocument → Firebase Storage → Veryfi Cloud Function;
         care team dial uses ACTION_DIAL only
         (no CALL_PHONE). Profile darkModeEnabled persisted in hubSettings. Runtime permissions in EobNavHost. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EOBme">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EOBme"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".data.EobFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>