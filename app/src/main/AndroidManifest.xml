<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- INTERNET — Firebase Auth, Firestore, Storage; EOB upload/sync (EobRepository / EobViewModel) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ACCESS_NETWORK_STATE — connectivity checks before remote operations -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- CAMERA — hub Scan EOB → EobRoute.CameraCapture (CameraX); runtime request in EobNavHost -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- POST_NOTIFICATIONS — EobFirebaseMessagingService; runtime request API 33+ in EobNavHost -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- BILLING — Play Billing Client (com.android.billingclient:billing) -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <!-- Care team + smart bento (CPT ring / YTD deductible tracker via BentoSnapshotExtractor),
         EobViewModel HubUiState. Tap-to-call uses ACTION_DIAL (no CALL_PHONE).
         Library EOB upload uses SAF — no READ_MEDIA_* / READ_EXTERNAL_STORAGE. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EOBme">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EOBme"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".data.EobFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>