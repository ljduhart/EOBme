<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- INTERNET — Firebase Auth, Firestore, Storage; EOB sync via EobViewModel / FirebaseEobRepository -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ACCESS_NETWORK_STATE — connectivity checks before remote claim/news sync -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- CAMERA — EobRoute.CameraCapture (CameraX); runtime request in EobNavHost -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- POST_NOTIFICATIONS — EobFirebaseMessagingService; runtime request API 33+ in EobNavHost -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- BILLING — Play Billing Client -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <!-- Hub: Appeal Generator shield card + Provider Directory assurance badges via EobViewModel.
         Onboarding (Splash → Language → Intro) unchanged; no extra permissions. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EOBme">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EOBme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".data.EobFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>