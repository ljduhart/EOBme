<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Firebase sync, news, profile, and EOB upload (EobRepository / EobViewModel) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Hub bottom bar Scan EOB → CameraCaptureScreen (CameraX) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- FCM push (EobFirebaseMessagingService); requested at runtime on API 33+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Play billing (reserved for in-app purchases) -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Home hub: care team smart cards (flip/press animations), appointment calendar — EobViewModel
         HubUiState (device-local; no extra permissions). Camera, network, notifications above. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EOBme">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EOBme"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".data.EobFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>